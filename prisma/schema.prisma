generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String   @default("operator") // admin, operator
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_tokens")
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String
  address       String
  city          String
  state         String
  zipCode       String    @map("zip_code")
  panNumber     String?   @map("pan_number")
  aadhaarNumber String?   @map("aadhaar_number")
  dateOfBirth   DateTime? @map("date_of_birth")
  occupation    String?
  annualIncome  Float?    @map("annual_income")
  accountType   String    @map("account_type")
  purpose       String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]

  @@map("customers")
}

model Account {
  id               String           @id @default(cuid())
  accountNumber    String           @unique
  customerId       String
  accountType      String           // FD, RD, LOAN
  status           String           @default("ACTIVE") // ACTIVE, MATURITY_PENDING, CLOSING_PENDING, CLOSED
  principalAmount  Float
  interestRate     Float
  tenure           Int
  startDate        DateTime
  maturityDate     DateTime?
  closedAt         DateTime?        @map("closed_at")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accountRules     AccountRules?
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  suggestedEntries SuggestedEntry[]
  transactions     Transaction[]
  installmentEntries InstallmentEntry[]
  emiEntries       EMIEntry[]

  @@map("accounts")
}

model AccountRules {
  id                  String             @id @default(cuid())
  accountId           String             @unique @map("account_id")
  interestMode        String             @default("maturity") @map("interest_mode") // monthly, maturity-only
  payoutMode          String             @default("reinvest") @map("payout_mode") // reinvest, paid-out
  loanMethod          String?            @map("loan_method") // flat, reducing
  rdInterestMethod    String?            @map("rd_interest_method") // installment_weighted, monthly_balance
  rdBalanceDateRule   String?            @map("rd_balance_date_rule") // month_end, fixed_day
  rdBalanceDay        Int?               @map("rd_balance_day") // for fixed_day rule
  emiAmount           Float?             @map("emi_amount")
  emiDueDay           Int?               @map("emi_due_day")
  gracePeriodDays     Int?               @default(0) @map("grace_period_days")
  penaltyRate         Float?             @default(1.0) @map("penalty_rate") // percentage
  roundingMode        String             @default("nearest") @map("rounding_mode")
  roundingPrecision   Int                @default(2) @map("rounding_precision")
  numberingTemplateId String?            @map("numbering_template_id")
  customFields        Json?              @map("custom_fields")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  account             Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  numberingTemplate   NumberingTemplate? @relation(fields: [numberingTemplateId], references: [id])

  @@map("account_rules")
}

model NumberingTemplate {
  id                String         @id @default(cuid())
  name              String
  template          String
  description       String?
  isActive          Boolean        @default(true) @map("is_active")
  accountType       String         @map("account_type")
  sequenceStart     Int            @default(1) @map("sequence_start")
  currentSequence   Int            @default(0) @map("current_sequence")
  requiredVariables Json?          @map("required_variables")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  accountRules      AccountRules[]

  @@map("numbering_templates")
}

model Transaction {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  type            String   // INTEREST, INSTALLMENT, EMI, PENALTY, PRINCIPAL_PAYMENT, MATURITY_PAYOUT
  amount          Float
  balance         Float?
  description     String?
  reference       String?
  transactionDate DateTime @default(now()) @map("transaction_date")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model SuggestedEntry {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  type            String   // INTEREST, EMI_DUE, PENALTY
  amount          Float
  description     String?
  runDate         DateTime @default(now()) @map("run_date")
  periodStartDate DateTime @map("period_start_date")
  periodEndDate   DateTime @map("period_end_date")
  status          String   @default("pending") // pending, approved, rejected
  rejectionReason String?  @map("rejection_reason")
  approvedBy      String?  @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("suggested_entries")
}

model InstallmentEntry {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  amount          Float
  installmentDate DateTime @map("installment_date")
  description     String?
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("installment_entries")
}

model EMIEntry {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  emiNumber       Int      @map("emi_number")
  dueDate         DateTime @map("due_date")
  emiAmount       Float    @map("emi_amount")
  principalAmount Float    @map("principal_amount")
  interestAmount  Float    @map("interest_amount")
  penaltyAmount   Float?   @map("penalty_amount")
  status          String   @default("DUE") // DUE, PAID, PART_PAID, OVERDUE
  paidAmount      Float?   @map("paid_amount")
  paidDate        DateTime? @map("paid_date")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("emi_entries")
}

model AccountClosure {
  id                String   @id @default(cuid())
  accountId         String   @unique @map("account_id")
  closureType       String   @map("closure_type") // maturity, premature
  principalAmount   Float    @map("principal_amount")
  interestAmount    Float    @map("interest_amount")
  penaltyAmount     Float?   @map("penalty_amount")
  totalPayable      Float    @map("total_payable")
  closureDate       DateTime @map("closure_date")
  reason            String?
  closedBy          String   @map("closed_by")
  approvedBy        String?  @map("approved_by")
  approvedAt        DateTime? @map("approved_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("account_closures")
}
