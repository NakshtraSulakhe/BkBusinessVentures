generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_tokens")
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String
  address       String
  city          String
  state         String
  zipCode       String    @map("zip_code")
  panNumber     String?   @map("pan_number")
  aadhaarNumber String?   @map("aadhaar_number")
  dateOfBirth   DateTime? @map("date_of_birth")
  occupation    String?
  annualIncome  Float?    @map("annual_income")
  accountType   String    @map("account_type")
  purpose       String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts      Account[]
  
  @@map("customers")
}

// Account Master for FD/RD/Loan
model Account {
  id                String    @id @default(cuid())
  accountNumber     String    @unique
  customerId        String
  accountType       String
  principalAmount   Float
  interestRate      Float
  tenure            Int
  startDate         DateTime
  maturityDate      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  accountRules      AccountRules?
  transactions      Transaction[]
  
  @@map("accounts")
}

// Per-account rules configuration
model AccountRules {
  id                  String   @id @default(cuid())
  accountId           String   @unique @map("account_id")
  
  // Interest configuration
  interestMode        String   @map("interest_mode") @default("maturity")
  payoutMode          String   @map("payout_mode") @default("reinvest")
  
  // Loan specific
  loanMethod          String?  @map("loan_method")
  emiAmount           Float?   @map("emi_amount")
  emiDueDay           Int?     @map("emi_due_day")
  gracePeriodDays     Int?     @map("grace_period_days") @default(0)
  
  // General settings
  roundingMode        String   @map("rounding_mode") @default("nearest")
  roundingPrecision   Int      @map("rounding_precision") @default(2)
  
  // Numbering template reference
  numberingTemplateId String?  @map("numbering_template_id")
  
  // Custom field overrides
  customFields        Json?   @map("custom_fields")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  account             Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  numberingTemplate   NumberingTemplate? @relation(fields: [numberingTemplateId], references: [id])
  
  @@map("account_rules")
}

// Numbering templates for account generation
model NumberingTemplate {
  id                  String   @id @default(cuid())
  name                String
  template            String
  description         String?
  isActive            Boolean  @default(true) @map("is_active")
  accountType         String   @map("account_type")
  sequenceStart       Int      @map("sequence_start") @default(1)
  currentSequence     Int      @map("current_sequence") @default(0)
  
  // Template validation
  requiredVariables   Json?    @map("required_variables")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  accountRules        AccountRules[]
  
  @@map("numbering_templates")
}

// Transaction history
model Transaction {
  id            String    @id @default(cuid())
  accountId     String    @map("account_id")
  type          String
  amount        Float
  balance       Float?
  description   String?
  reference     String?
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@map("transactions")
}
